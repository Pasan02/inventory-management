<Window x:Class="inventory_management.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:inventory_management"
        xmlns:vm="clr-namespace:inventory_management.ViewModels"
        xmlns:views="clr-namespace:inventory_management.Views"
        xmlns:converters="clr-namespace:inventory_management.Converters"
        mc:Ignorable="d"
        Title="{Binding Title}" WindowState="Maximized" WindowStartupLocation="CenterScreen">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Title - Removing as requested to clean up UI (LoginView has its own header) -->
        <!-- <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/> -->

        <!-- Main Content Area with Navigation Switcher -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}">
            <ContentControl.Resources>
                
                <!-- If CurrentViewModel is NULL, show the Home Menu (Buttons) -->
                <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                    <UniformGrid Columns="2" Rows="3" Margin="50">
                        <Button Command="{Binding DataContext.NavigateToAddStockCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="20">
                            <StackPanel>
                                <TextBlock Text="➕" HorizontalAlignment="Center" FontSize="64" Margin="0,0,0,10"/>
                                <TextBlock Text="Add Stock" FontSize="32" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DataContext.NavigateToRemoveStockCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="20">
                            <StackPanel>
                                <TextBlock Text="➖" HorizontalAlignment="Center" FontSize="64" Margin="0,0,0,10"/>
                                <TextBlock Text="Remove Stock" FontSize="32" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Command="{Binding DataContext.NavigateToSearchCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="20">
                            <StackPanel>
                                <TextBlock Text="🔍" HorizontalAlignment="Center" FontSize="64" Margin="0,0,0,10"/>
                                <TextBlock Text="Search / Items" FontSize="32" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                         <!-- Added Create Item Button for Phase 2 -->
                        <Button Command="{Binding DataContext.NavigateToCreateItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="20">
                            <StackPanel>
                                <TextBlock Text="🆕" HorizontalAlignment="Center" FontSize="64" Margin="0,0,0,10"/>
                                <TextBlock Text="New Item" FontSize="32" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding DataContext.NavigateToReportsCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="20">
                            <StackPanel>
                                <TextBlock Text="📊" HorizontalAlignment="Center" FontSize="64" Margin="0,0,0,10"/>
                                <TextBlock Text="Reports" FontSize="32" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding DataContext.LogoutCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="20">
                            <StackPanel>
                                <TextBlock Text="🔙" HorizontalAlignment="Center" FontSize="64" Margin="0,0,0,10"/>
                                <TextBlock Text="Sign Out" FontSize="32" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                    <views:LoginView/>
                </DataTemplate>

                <!-- Phase 2: Create Item View -->
                <DataTemplate DataType="{x:Type vm:ItemCreationViewModel}">
                    <views:ItemCreationView/>
                </DataTemplate>

                <!-- Phase 3: Add/Remove Stock Views -->
                <DataTemplate DataType="{x:Type vm:AddStockViewModel}">
                    <views:AddStockView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:RemoveStockViewModel}">
                    <views:RemoveStockView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:SearchItemsViewModel}">
                    <views:SearchItemsView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                    <views:ReportsView/>
                </DataTemplate>

                <!-- Future Views will be added here -->

            </ContentControl.Resources>
        </ContentControl>

        <!-- Navigation Buttons: Back and Refresh -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,0,0,0">
            <!-- Back Button -->
            <Button Command="{Binding GoHomeCommand}" 
                Visibility="{Binding CurrentViewModel, Converter={x:Static converters:NotHomeViewModelToVisibilityConverter.Instance}, FallbackValue=Collapsed}"
                Padding="10,5" MinWidth="80" MinHeight="34">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="20" Height="20" Margin="0,0,5,0">
                        <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Fill="Black"/>
                    </Viewbox>
                    <TextBlock Text="Back" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Refresh Button (Reports Only) -->
            <Button Command="{Binding CurrentViewModel.LoadReportsCommand}" 
                    Visibility="{Binding CurrentViewModel, Converter={x:Static converters:ReportsViewModelToVisibilityConverter.Instance}, FallbackValue=Collapsed}"
                    Margin="20,0,0,0" Padding="10,5" MinWidth="80" MinHeight="34">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="20" Height="20" Margin="0,0,5,0">
                        <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Fill="Black"/>
                    </Viewbox>
                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            
             <!-- Refresh Button (Add Stock) -->
            <Button Command="{Binding CurrentViewModel.LoadItemsCommandCommand}" 
                    Visibility="{Binding CurrentViewModel, Converter={x:Static converters:AddStockViewModelToVisibilityConverter.Instance}, FallbackValue=Collapsed}"
                    Margin="20,0,0,0" Padding="10,5" MinWidth="80" MinHeight="34">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="20" Height="20" Margin="0,0,5,0">
                        <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Fill="Black"/>
                    </Viewbox>
                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Refresh Button (Remove Stock) -->
            <Button Command="{Binding CurrentViewModel.LoadItemsCommandCommand}" 
                    Visibility="{Binding CurrentViewModel, Converter={x:Static converters:RemoveStockViewModelToVisibilityConverter.Instance}, FallbackValue=Collapsed}"
                    Margin="20,0,0,0" Padding="10,5" MinWidth="80" MinHeight="34">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="20" Height="20" Margin="0,0,5,0">
                        <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Fill="Black"/>
                    </Viewbox>
                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Refresh Button (Item Creation) -->
            <Button Command="{Binding CurrentViewModel.LoadReferenceDataCommand}" 
                    Visibility="{Binding CurrentViewModel, Converter={x:Static converters:ItemCreationViewModelToVisibilityConverter.Instance}, FallbackValue=Collapsed}"
                    Margin="20,0,0,0" Padding="10,5" MinWidth="80" MinHeight="34">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="20" Height="20" Margin="0,0,5,0">
                        <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Fill="Black"/>
                    </Viewbox>
                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

    </Grid>
</Window>
