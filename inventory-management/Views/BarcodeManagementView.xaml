<UserControl x:Class="inventory_management.Views.BarcodeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1280">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="28">
                <StackPanel>
                    <TextBlock Text="Barcode Center"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryColor}"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding ScannerStatus}"
                               FontSize="16"
                               Foreground="{StaticResource TextSecondaryColor}"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Search Items"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryColor}"
                               Margin="0,0,0,8"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="56"
                             FontSize="20"
                             VerticalContentAlignment="Center"/>

                    <ListBox ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedItem}"
                             Height="430"
                             Margin="0,18,0,0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12"
                                        Margin="0,0,0,8"
                                        Background="{StaticResource SurfaceColor}"
                                        BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Barcode}" FontSize="18" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding PartType.Name}" FontSize="16"/>
                                        <TextBlock>
                                            <Run Text="{Binding PartBrand.Name}"/>
                                            <Run Text=" | "/>
                                            <Run Text="{Binding VehicleModel.Manufacturer.Name}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding VehicleModel.Name}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource CardBorderStyle}" Padding="28" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Barcode Preview"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,18"/>

                        <Border Background="White"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedItem.PartType.Name, TargetNullValue=Select an item}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <Image Source="{Binding BarcodePreview}"
                                       Height="150"
                                       Stretch="Uniform"
                                       Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding BarcodeText}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Refresh Barcode Preview"
                                Command="{Binding PrintPreviewBarcodeCommand}"
                                Height="50"
                                Margin="0,18,0,0"
                                FontSize="18"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CompactCardStyle}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Print Labels"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,18"/>

                        <TextBlock Text="Printer" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding Printers}"
                                  SelectedItem="{Binding SelectedPrinter}"
                                  Height="52"
                                  FontSize="18"/>

                        <TextBlock Text="Label Profile" FontSize="16" FontWeight="SemiBold" Margin="0,12,0,6"/>
                        <ComboBox ItemsSource="{Binding LabelProfiles}"
                                  SelectedItem="{Binding SelectedLabelProfile}"
                                  Height="52"
                                  FontSize="18"/>

                        <TextBlock Text="Quantity" FontSize="16" FontWeight="SemiBold" Margin="0,12,0,6"/>
                        <TextBox Text="{Binding PrintQuantity}"
                                 Height="52"
                                 FontSize="18"
                                 VerticalContentAlignment="Center"/>

                        <Button Content="Refresh Printers"
                                Command="{Binding LoadPrintersCommand}"
                                Height="48"
                                Margin="0,18,0,10"
                                FontSize="18"/>

                        <Button Content="Print Barcode Labels"
                                Command="{Binding PrintBarcodeCommand}"
                                Height="56"
                                FontSize="20"
                                FontWeight="Bold"/>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,14,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryColor}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
