<UserControl x:Class="inventory_management.Views.AddStockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:inventory_management.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Add Stock" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,20,0">
            <TextBlock Text="Scan / Enter Barcode"/>
            <TextBox Text="{Binding BarcodeInput}" Margin="0,0,0,10"/>

            <Button Command="{Binding LookupItemCommand}" Content="Load Item" Height="32" Margin="0,0,0,20"/>

            <TextBlock Text="Quantity to Add"/>
            <TextBox Text="{Binding Quantity}" Margin="0,0,0,20"/>

            <Button Command="{Binding AddStockCommand}" Content="Add Stock" Height="40" FontSize="16"/>

            <TextBlock Text="{Binding StatusMessage}" Foreground="Red" Margin="0,20,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Column="1" Grid.Row="1" Padding="10" BorderBrush="#DDD" BorderThickness="1"
                Visibility="{Binding CurrentItem, Converter={x:Static converters:NotNullToVisibilityConverter.Instance}}">
            <StackPanel>
                <TextBlock Text="Item Details" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding CurrentItem.PartType.Name, StringFormat=Part Type: {0}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding CurrentItem.PartBrand.Name, StringFormat=Brand: {0}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding CurrentItem.VehicleModel.Manufacturer.Name, StringFormat=Make: {0}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding CurrentItem.VehicleModel.Name, StringFormat=Model: {0}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding CurrentItem.Rack.LocationCode, StringFormat=Rack: {0}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding CurrentQuantity, StringFormat=Current Stock: {0}}" Margin="0,10,0,0" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
