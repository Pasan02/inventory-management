<UserControl x:Class="inventory_management.Views.RemoveStockView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:converters="clr-namespace:inventory_management.Converters"
         mc:Ignorable="d" 
         d:DesignHeight="600" d:DesignWidth="800">
<UserControl.Resources>
    <!-- Style to prevent ListBox from changing selection on mouse wheel scroll -->
    <Style TargetType="ListBox">
        <EventSetter Event="PreviewMouseWheel" Handler="ListBox_PreviewMouseWheel"/>
    </Style>
</UserControl.Resources>
<Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="244*"/>
            <ColumnDefinition Width="263*"/>
            <ColumnDefinition Width="253*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,40,0" Grid.ColumnSpan="3">
            <TextBlock Text="Search Item by Barcode" FontSize="24"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Height="70" FontSize="22" VerticalContentAlignment="Center"/>
            <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" DisplayMemberPath="Barcode" Height="150" Margin="0,0,0,20" FontSize="20"/>

            <TextBlock Text="Selected Barcode" FontSize="24"/>
            <TextBox Text="{Binding BarcodeInput}" Margin="0,0,0,20" Height="80" FontSize="24" VerticalContentAlignment="Center">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding ScanRemoveCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <Button Command="{Binding LookupItemCommand}" Content="Load Item Details" Height="60" Margin="0,0,0,30" FontSize="24"/>

            <TextBlock Text="Quantity to Remove" FontSize="24"/>
            <TextBox Text="{Binding Quantity}" Margin="0,0,0,30" Height="70" FontSize="26" VerticalContentAlignment="Center"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Command="{Binding ResetCommand}" Content="Reset" Height="70" FontSize="28" FontWeight="Bold" Background="Black" Foreground="White"/>
                <Button Grid.Column="2" Command="{Binding RemoveStockCommand}" Content="Remove Stock" Height="70" FontSize="28" FontWeight="Bold"/>
            </Grid>

        </StackPanel>

        <Border Grid.Column="3" Padding="10" BorderBrush="#DDD" BorderThickness="1"
                Visibility="{Binding CurrentItem, Converter={x:Static converters:NotNullToVisibilityConverter.Instance}}">
            <StackPanel>
                <TextBlock Text="Item Details" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding CurrentItem.PartType.Name, StringFormat=Part Type: {0}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding CurrentItem.PartBrand.Name, StringFormat=Brand: {0}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding CurrentItem.VehicleModel.Manufacturer.Name, StringFormat=Make: {0}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding CurrentItem.VehicleModel.Name, StringFormat=Model: {0}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding CurrentItem.Rack.LocationCode, StringFormat=Rack: {0}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding CurrentQuantity, StringFormat=Current Stock: {0}}" Margin="0,10,0,0" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
