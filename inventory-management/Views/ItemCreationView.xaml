<UserControl x:Class="inventory_management.Views.ItemCreationView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:inventory_management.Views"
         mc:Ignorable="d" 
         d:DesignHeight="600" d:DesignWidth="800">
<UserControl.Resources>
    <!-- Modern ComboBox Style with rounded corners -->
    <Style TargetType="ComboBox">
        <EventSetter Event="PreviewMouseWheel" Handler="ComboBox_PreviewMouseWheel"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="MainGrid">
                        <Border x:Name="MainBorder" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" 
                                                Grid.ColumnSpan="2"
                                                Content="{TemplateBinding SelectionBoxItem}" 
                                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" 
                                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                                Margin="10,0,35,0"
                                                IsHitTestVisible="False"/>
                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#555" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                                      Margin="0,0,10,0" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <!-- Transparent button overlay to make entire ComboBox clickable -->
                        <ToggleButton x:Name="ToggleButton" 
                                    Focusable="False" 
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                    ClickMode="Press"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Cursor="Hand"
                                    OverridesDefaultStyle="True"
                                    FocusVisualStyle="{x:Null}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup" 
                               AllowsTransparency="True" 
                               Placement="Bottom" 
                               IsOpen="{TemplateBinding IsDropDownOpen}" 
                               PopupAnimation="Slide"
                               Width="{Binding ActualWidth, ElementName=MainGrid}">
                            <Border Background="White" 
                                    BorderBrush="#CCCCCC" 
                                    BorderThickness="1" 
                                    CornerRadius="8" 
                                    Margin="0,4,0,0"
                                    MaxHeight="300">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                                </Border.Effect>
                                <ScrollViewer MaxHeight="300">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="#0078D4"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="MainBorder" Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="MinHeight" Value="44"/>
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="0,4,0,10"/>
    </Style>
    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
        <Setter Property="Margin" Value="0,8,0,4"/>
    </Style>
    <Style x:Key="FormButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="MinHeight" Value="36"/>
    </Style>
</UserControl.Resources>
<Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Add New Item" FontSize="36" FontWeight="Bold" Margin="0,0,0,30"/>

        <!-- Form -->
        <!-- Fixed Panel for Barcode (Top-Right, aligned with start of form content) - Outside ScrollViewer to prevent scrolling -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Scrollable Form Area -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,30,0">

                    <TextBlock Text="Part Type" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" 
                                  ItemsSource="{Binding PartTypes}" 
                                  DisplayMemberPath="Name" 
                                  SelectedItem="{Binding SelectedPartType}"
                                  IsEditable="False"
                                  MinHeight="44"
                                  Margin="0,4,10,0"/>
                        <Button Grid.Column="1" 
                                Content="Add Image" 
                                Command="{Binding BrowsePartTypeImageCommand}" 
                                Style="{StaticResource FormButtonStyle}"
                                Width="120" 
                                Height="36" 
                                ToolTip="Add or update image for selected part type"/>
                    </Grid>
                    <TextBlock Text="Image Path:" FontSize="16"/>
                    <TextBox Text="{Binding NewPartTypeImagePath}" IsReadOnly="True" Background="Transparent" BorderThickness="0" FontSize="16"/>

                    <TextBlock Text="Manufacturer" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" 
                                  ItemsSource="{Binding Manufacturers}" 
                                  DisplayMemberPath="Name" 
                                  SelectedItem="{Binding SelectedManufacturer}"
                                  IsEditable="False"
                                  MinHeight="44"
                                  Margin="0,4,10,0"/>
                        <Button Grid.Column="1" 
                                Content="Add Logo" 
                                Command="{Binding BrowseManufacturerLogoCommand}" 
                                Style="{StaticResource FormButtonStyle}"
                                Width="120" 
                                Height="36" 
                                ToolTip="Add or update logo for selected manufacturer"/>
                    </Grid>
                    <TextBlock Text="Logo Path:" FontSize="16"/>
                    <TextBox Text="{Binding NewManufacturerLogoPath}" IsReadOnly="True" Background="Transparent" BorderThickness="0" FontSize="16"/>


                    <TextBlock Text="Vehicle Model" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Models}" 
                              DisplayMemberPath="Name" 
                              SelectedItem="{Binding SelectedModel}"
                              IsEditable="False"
                              MinHeight="44"
                              Margin="0,4,0,10"/>

                    <TextBlock Text="Year Range" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0" Text="{Binding NewModelName}" Height="40" VerticalContentAlignment="Center"/>
                        <TextBox Grid.Column="2" Text="{Binding NewModelYearRange}" Height="40" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="4" Content="Add Model" Command="{Binding AddModelCommand}" Style="{StaticResource FormButtonStyle}" Width="120" Height="36" Padding="0"/>
                    </Grid>

                    <TextBlock Text="Brand" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Brands}" 
                              DisplayMemberPath="Name" 
                              SelectedItem="{Binding SelectedBrand}"
                              IsEditable="False"
                              MinHeight="44"
                              Margin="0,4,0,10"/>

                    <TextBlock Text="Country of Origin" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding CountryOfOrigin}"/>

                    <TextBlock Text="Description / Notes" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding Description}" Height="100" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Item Image" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding ImagePath}" Margin="0,0,10,0" Height="36" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseItemImageCommand}" Style="{StaticResource FormButtonStyle}" Width="100" Height="36" Padding="5,0"/>
                    </Grid>

                    <TextBlock Text="Rack Location" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Racks}" 
                              DisplayMemberPath="LocationCode" 
                              SelectedItem="{Binding SelectedRack}"
                              IsEditable="False"
                              MinHeight="44"
                              Margin="0,4,0,10"/>

                    <TextBlock Text="Low Stock Threshold" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding LowStockThreshold}"/>

                    <Grid Margin="0,30,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding ResetCommand}" Content="Reset" Height="56" FontSize="22" FontWeight="Bold" Background="Black" Foreground="White" Padding="16,8"/>
                        <Button Grid.Column="2" Command="{Binding SaveItemCommand}" Content="Save Item" Height="56" FontSize="22" FontWeight="Bold" Padding="16,8"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Fixed Right Column: Result / Barcode / Preview -->
            <!-- Using VerticalAlignment="Top" and Margin matches the top of scroll view content -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="center">
                <Border Background="White" Padding="15" CornerRadius="8" Width="400" HorizontalAlignment="center" MinHeight="250">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Generated Barcode" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15" FontSize="18"/>
                        <Image Source="{Binding BarcodeImage}" Height="80" Stretch="Uniform" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding SelectedBarcode}" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Navigation Footer can be in Main View or here -->
    </Grid>
</UserControl>
