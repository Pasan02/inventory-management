<UserControl x:Class="inventory_management.Views.ItemCreationView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:inventory_management.Views"
         mc:Ignorable="d" 
         d:DesignHeight="600" d:DesignWidth="800">
<UserControl.Resources>
    <!-- Modern ComboBox Style with rounded corners -->
    <Style TargetType="ComboBox">
        <EventSetter Event="PreviewMouseWheel" Handler="ComboBox_PreviewMouseWheel"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="MainGrid">
                        <Border x:Name="MainBorder" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" 
                                                Grid.ColumnSpan="2"
                                                Content="{TemplateBinding SelectionBoxItem}" 
                                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" 
                                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                                Margin="10,0,35,0"
                                                IsHitTestVisible="False"/>
                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#555" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                                      Margin="0,0,10,0" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <!-- Transparent button overlay to make entire ComboBox clickable -->
                        <ToggleButton x:Name="ToggleButton" 
                                    Focusable="False" 
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                    ClickMode="Press"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Cursor="Hand"/>
                        <Popup x:Name="PART_Popup" 
                               AllowsTransparency="True" 
                               Placement="Bottom" 
                               IsOpen="{TemplateBinding IsDropDownOpen}" 
                               PopupAnimation="Slide"
                               Width="{Binding ActualWidth, ElementName=MainGrid}">
                            <Border Background="White" 
                                    BorderBrush="#CCCCCC" 
                                    BorderThickness="1" 
                                    CornerRadius="8" 
                                    Margin="0,4,0,0"
                                    MaxHeight="300">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                                </Border.Effect>
                                <ScrollViewer MaxHeight="300">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="#0078D4"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="MainBorder" Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="FontSize" Value="18"/>
    </Style>
</UserControl.Resources>
<Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Form -->
        <!-- Fixed Panel for Barcode (Top-Right, aligned with start of form content) - Outside ScrollViewer to prevent scrolling -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Scrollable Form Area -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,30,0">

                    <TextBlock Text="Part Type"/>
                    <ComboBox ItemsSource="{Binding PartTypes}" 
                              DisplayMemberPath="Name" 
                              SelectedItem="{Binding SelectedPartType}"
                              IsEditable="False"
                              MinHeight="60"
                              Margin="0,0,0,10"/>

                    <!-- Quick Add Part Type -->
                    <Border Background="#F0F0F0" Padding="15" Margin="0,0,0,20" CornerRadius="5">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding NewPartTypeName}" Margin="0,0,10,0" Height="50" FontSize="16" VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="Pick" Command="{Binding BrowsePartTypeImageCommand}" Width="100" Height="50" FontSize="16" Margin="0,0,10,0"/>
                                <Button Grid.Column="2" Content="Add" Command="{Binding AddPartTypeCommand}" FontWeight="Bold" Width="100" Height="50" FontSize="16"/>
                            </Grid>
                            <TextBlock Text="Image Path:" FontSize="16" Margin="0,10,0,5"/>
                            <TextBox Text="{Binding NewPartTypeImagePath}" IsReadOnly="True" Background="Transparent" BorderThickness="0" FontSize="16" Height="50" VerticalContentAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Manufacturer"/>
                    <ComboBox ItemsSource="{Binding Manufacturers}" 
                              DisplayMemberPath="Name" 
                              SelectedItem="{Binding SelectedManufacturer}"
                              IsEditable="False"
                              MinHeight="60"
                              Margin="0,0,0,10"/>

                    <!-- Quick Add Manufacturer -->
                    <Border Background="#F0F0F0" Padding="15" Margin="0,0,0,20" CornerRadius="5">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding NewManufacturerName}" Margin="0,0,10,0" Height="50" FontSize="16" VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="Pick" Command="{Binding BrowseManufacturerLogoCommand}" Width="100" Height="50" FontSize="16" Margin="0,0,10,0"/>
                                <Button Grid.Column="2" Content="Add" Command="{Binding AddManufacturerCommand}" FontWeight="Bold" Width="100" Height="50" FontSize="16"/>
                            </Grid>
                            <TextBlock Text="Logo Path:" FontSize="16" Margin="0,10,0,5"/>
                            <TextBox Text="{Binding NewManufacturerLogoPath}" IsReadOnly="True" Background="Transparent" BorderThickness="0" FontSize="16" Height="50" VerticalContentAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>


                    <TextBlock Text="Vehicle Model"/>
                    <ComboBox ItemsSource="{Binding Models}" 
                              DisplayMemberPath="Name" 
                              SelectedItem="{Binding SelectedModel}"
                              IsEditable="False"
                              MinHeight="60"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="Year Range"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0" Text="{Binding NewModelName}" Height="50" FontSize="18" VerticalContentAlignment="Center" Padding="10"/>
                        <TextBox Grid.Column="2" Text="{Binding NewModelYearRange}" Height="50" FontSize="18" VerticalContentAlignment="Center" Padding="10"/>
                        <Button Grid.Column="4" Content="Add Model" Command="{Binding AddModelCommand}" Width="120" Height="50" FontSize="16" Padding="5,0"/>
                    </Grid>

                    <TextBlock Text="Brand"/>
                    <ComboBox ItemsSource="{Binding Brands}" 
                              DisplayMemberPath="Name" 
                              SelectedItem="{Binding SelectedBrand}"
                              IsEditable="False"
                              MinHeight="60"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="Country of Origin"/>
                    <TextBox Text="{Binding CountryOfOrigin}"/>

                    <TextBlock Text="Description / Notes"/>
                    <TextBox Text="{Binding Description}" Height="100" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Item Image"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding ImagePath}" Margin="0,0,10,0" Height="40" FontSize="16" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseItemImageCommand}" Width="100" Height="40" FontSize="14" Padding="5,0"/>
                    </Grid>

                    <TextBlock Text="Rack Location"/>
                    <ComboBox ItemsSource="{Binding Racks}" 
                              DisplayMemberPath="LocationCode" 
                              SelectedItem="{Binding SelectedRack}"
                              IsEditable="False"
                              MinHeight="60"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="Low Stock Threshold"/>
                    <TextBox Text="{Binding LowStockThreshold}"/>

                    <Grid Margin="0,30,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding ResetCommand}" Content="Reset" Height="70" FontSize="28" FontWeight="Bold" Background="Black" Foreground="White"/>
                        <Button Grid.Column="2" Command="{Binding SaveItemCommand}" Content="Save Item" Height="70" FontSize="28" FontWeight="Bold"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Fixed Right Column: Result / Barcode / Preview -->
            <!-- Using VerticalAlignment="Top" and Margin matches the top of scroll view content -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Top">
                <Border Background="White" Padding="15" CornerRadius="8" Width="300" HorizontalAlignment="Left" MinHeight="150">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Generated Barcode" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15" FontSize="18"/>
                        <Image Source="{Binding BarcodeImage}" Height="80" Stretch="Uniform" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding SelectedBarcode}" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Navigation Footer can be in Main View or here -->
    </Grid>
</UserControl>