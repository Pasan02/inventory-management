<UserControl x:Class="inventory_management.Views.ItemCreationView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:inventory_management.Views"
         mc:Ignorable="d" 
         d:DesignHeight="600" d:DesignWidth="800">
<UserControl.Resources>
    <!-- Modern ComboBox Style with rounded corners -->
    <Style TargetType="ComboBox">
        <EventSetter Event="PreviewMouseWheel" Handler="ComboBox_PreviewMouseWheel"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="MainGrid" SnapsToDevicePixels="true">
                        <Popup x:Name="PART_Popup" 
                               AllowsTransparency="True" 
                               Placement="Bottom" 
                               IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                               PopupAnimation="Slide"
                               Width="{Binding ActualWidth, ElementName=MainGrid}"
                               StaysOpen="False">
                            <Border Background="White" 
                                    BorderBrush="#CCCCCC" 
                                    BorderThickness="1" 
                                    CornerRadius="8" 
                                    Margin="0,4,0,0"
                                    MaxHeight="300">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                                </Border.Effect>
                                <ScrollViewer MaxHeight="300">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>

                        <ToggleButton x:Name="ToggleButton" 
                                    Focusable="False" 
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                    ClickMode="Press"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="{TemplateBinding Background}"
                                    Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="MainBorder" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0" 
                                                            Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" 
                                                            ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" 
                                                            ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}" 
                                                            HorizontalAlignment="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource AncestorType=ComboBox}}" 
                                                            VerticalAlignment="{Binding VerticalContentAlignment, RelativeSource={RelativeSource AncestorType=ComboBox}}" 
                                                            Margin="10,0,35,0"/>
                                            <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#555" 
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                  Margin="0,0,10,0"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                             <!-- Note: We can't target the border inside the ToggleButton template directly from here easily without triggers inside. 
                                  Simplifying: Let's move styling to ToggleButton resources or just rely on transparency overlap if needed, 
                                  but standard approach is usually better. 
                                  Actually, since we moved the border INTO the ToggleButton, we should act on the ToggleButton properties or use triggers inside ToggleButton template.
                                  For simpler fix, let's keep the border outside and just overlay the toggle button, but FIX THE HIT TEST. -->
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <!-- reset of style -->
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="0,4,0,10"/>
    </Style>
    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
        <Setter Property="Margin" Value="0,8,0,4"/>
    </Style>
    <Style x:Key="FormButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="MinHeight" Value="36"/>
    </Style>
</UserControl.Resources>
<Grid Margin="20">
<Grid.ColumnDefinitions>
    <ColumnDefinition Width="2*"/>
    <ColumnDefinition Width="1*"/>
</Grid.ColumnDefinitions>

<!-- Scrollable Form Area -->
<ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,20,0" Padding="0,0,20,0">
    <StackPanel>

                    <TextBlock Text="Part Type" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" 
                                  ItemsSource="{Binding PartTypes}" 
                                  DisplayMemberPath="Name" 
                                  SelectedItem="{Binding SelectedPartType}"
                                  IsEditable="False"
                                  MinHeight="44"
                                  Margin="0,4,10,0"/>
                        <Button Grid.Column="1" 
                                Content="Add Image" 
                                Command="{Binding BrowsePartTypeImageCommand}" 
                                Style="{StaticResource FormButtonStyle}"
                                Width="120" 
                                Height="36" 
                                ToolTip="Add or update image for selected part type"/>
                    </Grid>

                    <TextBlock Text="Manufacturer" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" 
                                  ItemsSource="{Binding Manufacturers}" 
                                  DisplayMemberPath="Name" 
                                  SelectedItem="{Binding SelectedManufacturer}"
                                  IsEditable="False"
                                  MinHeight="44"
                                  Margin="0,4,10,0"/>
                        <Button Grid.Column="1" 
                                Content="Add Logo" 
                                Command="{Binding BrowseManufacturerLogoCommand}" 
                                Style="{StaticResource FormButtonStyle}"
                                Width="120" 
                                Height="36" 
                                ToolTip="Add or update logo for selected manufacturer"/>
                    </Grid>


                    <TextBlock Text="Vehicle Model" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Models}" 
                              DisplayMemberPath="Name" 
                              SelectedItem="{Binding SelectedModel}"
                              IsEditable="False"
                              MinHeight="44"
                              Margin="0,4,0,10"
                              IsHitTestVisible="True"/>

                    <TextBlock Text="Year Range" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0" Text="{Binding NewModelName}" Height="40" VerticalContentAlignment="Center"/>
                        <TextBox Grid.Column="2" Text="{Binding NewModelYearRange}" Height="40" VerticalContentAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Brand" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Brands}" 
                              DisplayMemberPath="Name" 
                              SelectedItem="{Binding SelectedBrand}"
                              IsEditable="False"
                              MinHeight="44"
                              Margin="0,4,0,10"/>

                    <TextBlock Text="Country of Origin" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding CountryOfOrigin}"/>

                    <TextBlock Text="Description / Notes" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding Description}" Height="100" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Item Image" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,20">
                        <Button Content="Browse" Command="{Binding BrowseItemImageCommand}" Style="{StaticResource FormButtonStyle}" Width="100" Height="36" Padding="5,0" HorizontalAlignment="Left" Margin="0,0,0,0"/>
                    </Grid>

                    <TextBlock Text="Rack Location" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Racks}" 
                              DisplayMemberPath="LocationCode" 
                              SelectedItem="{Binding SelectedRack}"
                              IsEditable="False"
                              MinHeight="44"
                              Margin="0,4,0,10"/>

                    <TextBlock Text="Low Stock Threshold" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding LowStockThreshold}"/>

                    <Grid Margin="0,30,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding ResetCommand}" Content="Reset" Height="56" FontSize="22" FontWeight="Bold" Background="Black" Foreground="White" Padding="16,8"/>
                        <Button Grid.Column="2" Command="{Binding SaveItemCommand}" Content="Save Item" Height="56" FontSize="22" FontWeight="Bold" Padding="16,8"/>
                    </Grid>

        </StackPanel>
    </ScrollViewer>

    <!-- Fixed Right Column: Barcode Preview - Centered Vertically -->
    <Grid Grid.Column="1">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="White" Padding="15" CornerRadius="8" Width="400" HorizontalAlignment="center" MinHeight="250">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Generated Barcode" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15" FontSize="18"/>
                        <Image Source="{Binding BarcodeImage}" Height="80" Stretch="Uniform" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding SelectedBarcode}" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
        </StackPanel>
    </Grid>
</Grid>
</UserControl>