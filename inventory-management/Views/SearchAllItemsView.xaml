<UserControl x:Class="inventory_management.Views.SearchAllItemsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:inventory_management.Converters"
             mc:Ignorable="d">
    <Border Style="{StaticResource CardBorderStyle}" Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="All Items for" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimaryColor}"
                           Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Manufacturer.Name}" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimaryColor}"
                           Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Part.Name}" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimaryColor}"
                           Margin="0,0,16,0"/>

                <Button Command="{Binding GoHomeCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8"
                        Cursor="Hand"
                        ToolTip="Go to Home"
                        VerticalAlignment="Center">
                    <Grid>
                        <Ellipse Width="40" Height="40" Fill="{StaticResource SurfaceColor}" Stroke="{StaticResource BorderColor}" StrokeThickness="1"/>
                        <Path Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" 
                              Fill="{StaticResource TextPrimaryColor}"
                              Stretch="Uniform"
                              Width="20"
                              Height="20"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                </StackPanel>
            </Grid>

            <!-- Search Box -->
            <Border Grid.Row="1" 
                    Background="{StaticResource SurfaceColor}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="12,8"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Viewbox Width="20" Height="20" Margin="0,0,10,0">
                        <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                              Fill="{StaticResource TextSecondaryColor}"/>
                    </Viewbox>
                    <TextBox Grid.Column="1" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="20"
                             Padding="0"
                             Margin="0"
                             VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style x:Key="ModernScrollThumb" TargetType="Thumb">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Thumb">
                                    <Border x:Name="ThumbBorder" Background="#CBD5E1" CornerRadius="4"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ThumbBorder" Property="Background" Value="#94A3B8"/>
                                        </Trigger>
                                        <Trigger Property="IsDragging" Value="True">
                                            <Setter TargetName="ThumbBorder" Property="Background" Value="#64748B"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="10"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="{TemplateBinding Background}" Width="{TemplateBinding Width}">
                                        <Track x:Name="PART_Track" IsDirectionReversed="true">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0" IsHitTestVisible="False"/>
                                            </Track.DecreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource ModernScrollThumb}"/>
                                            </Track.Thumb>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" IsHitTestVisible="False"/>
                                            </Track.IncreaseRepeatButton>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>
                <ItemsControl ItemsSource="{Binding ItemsView}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceColor}"
                                    CornerRadius="12"
                                    Padding="15"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1"
                                    Margin="6" 
                                    Width="260">
                                <Border.Effect>
                                    <DropShadowEffect Color="{Binding Source={StaticResource CardShadowColor}, Path=Color}" 
                                                    BlurRadius="12" 
                                                    ShadowDepth="0" 
                                                    Opacity="0.1"/>
                                </Border.Effect>
                                <StackPanel HorizontalAlignment="Stretch">
                                    <!-- Item Image -->
                                    <Border CornerRadius="8" ClipToBounds="True" Margin="0,0,0,12" BorderBrush="#EEEEEE" BorderThickness="1">
                                        <Image Height="140" 
                                               Stretch="UniformToFill"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Source="{Binding ImagePath, Converter={x:Static converters:RelativeAssetPathToImageSourceConverter.Instance}}"/>
                                    </Border>
                                    
                                    <!-- Model Name -->
                                    <TextBlock Text="{Binding Model}" 
                                               FontWeight="Bold" 
                                               FontSize="20"
                                               TextAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryColor}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Description}" 
                                               FontSize="14" 
                                               TextAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryColor}"
                                               Margin="0,0,0,16"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Details Section -->
                                    <Grid Margin="0,4,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Left Column -->
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <!-- Manufacturer -->
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="Manufacturer" 
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextSecondaryColor}"
                                                           Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Manufacturer}" 
                                                           FontWeight="Bold" 
                                                           FontSize="15"
                                                           Foreground="{StaticResource TextPrimaryColor}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            
                                            <!-- Brand -->
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="Brand" 
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextSecondaryColor}"
                                                           Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Brand}" 
                                                           FontWeight="Bold" 
                                                           FontSize="15"
                                                           Foreground="{StaticResource TextPrimaryColor}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            
                                            <!-- Origin -->
                                            <StackPanel>
                                                <TextBlock Text="Origin" 
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextSecondaryColor}"
                                                           Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Origin}" 
                                                           FontWeight="Bold" 
                                                           FontSize="15"
                                                           Foreground="{StaticResource TextPrimaryColor}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <!-- Right Column -->
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <!-- Stock -->
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="Stock" 
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextSecondaryColor}"
                                                           Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Quantity}" 
                                                           FontWeight="Bold" 
                                                           FontSize="16"
                                                           Foreground="{StaticResource PrimaryColor}"/>
                                            </StackPanel>

                                            <!-- Rack -->
                                            <StackPanel>
                                                <TextBlock Text="Rack" 
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextSecondaryColor}"
                                                           Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Rack}" 
                                                           FontWeight="Bold" 
                                                           FontSize="16"
                                                           Foreground="{StaticResource TextPrimaryColor}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="3" 
                       Text="{Binding StatusMessage}" 
                       Foreground="{StaticResource TextSecondaryColor}"
                       FontSize="18"
                       Margin="0,20,0,0"/>
        </Grid>
    </Border>
</UserControl>
