<UserControl x:Class="inventory_management.Views.SearchAllItemsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:inventory_management.Converters"
             mc:Ignorable="d">
    <Border Style="{StaticResource CardBorderStyle}" Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="All Items for" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimaryColor}"
                           Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Manufacturer.Name}" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimaryColor}"
                           Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Part.Name}" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimaryColor}"
                           Margin="0,0,20,0"/>
                           
                <!-- Include Out of Stock Checkbox -->
                <CheckBox Content="Include Out-of-Stock Items"
                          IsChecked="{Binding IncludeOutOfStock}"
                          VerticalAlignment="Center"
                          FontSize="16"
                          Foreground="{StaticResource TextSecondaryColor}"/>
            </StackPanel>

            <!-- Search Box -->
            <Border Grid.Row="1" 
                    Background="{StaticResource SurfaceColor}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="12,8"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Viewbox Width="20" Height="20" Margin="0,0,10,0">
                        <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                              Fill="{StaticResource TextSecondaryColor}"/>
                    </Viewbox>
                    <TextBox Grid.Column="1" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="20"
                             Padding="0"
                             Margin="0"
                             VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Resources>
                    <Style x:Key="ModernScrollThumb" TargetType="Thumb">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Thumb">
                                    <Border x:Name="ThumbBorder" Background="#CBD5E1" CornerRadius="4"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ThumbBorder" Property="Background" Value="#94A3B8"/>
                                        </Trigger>
                                        <Trigger Property="IsDragging" Value="True">
                                            <Setter TargetName="ThumbBorder" Property="Background" Value="#64748B"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Height" Value="10"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="{TemplateBinding Background}" Height="{TemplateBinding Height}">
                                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.LineLeftCommand" Opacity="0" IsHitTestVisible="False"/>
                                            </Track.DecreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource ModernScrollThumb}"/>
                                            </Track.Thumb>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.LineRightCommand" Opacity="0" IsHitTestVisible="False"/>
                                            </Track.IncreaseRepeatButton>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceColor}"
                                    CornerRadius="12"
                                    Padding="14"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1"
                                    Margin="8" 
                                    Width="240">
                                <Border.Effect>
                                    <DropShadowEffect Color="{Binding Source={StaticResource CardShadowColor}, Path=Color}" 
                                                    BlurRadius="12" 
                                                    ShadowDepth="0" 
                                                    Opacity="0.1"/>
                                </Border.Effect>
                                <StackPanel HorizontalAlignment="Center">
                                    <!-- Item Image -->
                                    <Image Width="212" Height="110" Margin="0,0,0,12" 
                                           Stretch="UniformToFill"
                                           VerticalAlignment="Center"
                                           Source="{Binding ImagePath, Converter={x:Static converters:RelativeAssetPathToImageSourceConverter.Instance}}"/>
                                    
                                    <!-- Model Name -->
                                    <TextBlock Text="{Binding Model}" 
                                               FontWeight="SemiBold" 
                                               FontSize="18"
                                               TextAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryColor}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"/>

                                    <!-- Details Section -->
                                    <StackPanel Margin="0,10,0,4" HorizontalAlignment="Stretch">
                                        <TextBlock Margin="0,0,0,6" TextWrapping="Wrap">
                                            <Run Text="Manufacturer: " FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextSecondaryColor}"/>
                                            <Run Text="{Binding Manufacturer}" FontSize="14" Foreground="{StaticResource TextPrimaryColor}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,6" TextWrapping="Wrap">
                                            <Run Text="Brand: " FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextSecondaryColor}"/>
                                            <Run Text="{Binding Brand}" FontSize="14" Foreground="{StaticResource TextPrimaryColor}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,6" TextWrapping="Wrap">
                                            <Run Text="Origin: " FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextSecondaryColor}"/>
                                            <Run Text="{Binding Origin}" FontSize="14" Foreground="{StaticResource TextPrimaryColor}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,6" TextWrapping="Wrap">
                                            <Run Text="Pcode: " FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextSecondaryColor}"/>
                                            <Run Text="{Binding SecretPriceCode}" FontSize="14" Foreground="{StaticResource TextPrimaryColor}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,6" TextWrapping="Wrap">
                                            <Run Text="Registered: " FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextSecondaryColor}"/>
                                            <Run Text="{Binding RegisteredDate, StringFormat='{}{0:yyyy-MM-dd}'}" FontSize="14" Foreground="{StaticResource TextPrimaryColor}"/>
                                        </TextBlock>
                                        <ScrollViewer MaxHeight="60" VerticalScrollBarVisibility="Auto" Margin="0,0,0,6">
                                            <TextBlock TextWrapping="Wrap">
                                                <Run Text="Compat: " FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextSecondaryColor}"/>
                                                <Run Text="{Binding CompatibleModelsText}" FontSize="14" Foreground="{StaticResource TextPrimaryColor}"/>
                                            </TextBlock>
                                        </ScrollViewer>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" TextWrapping="Wrap">
                                                <Run Text="Rack: " FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextSecondaryColor}"/>
                                                <Run Text="{Binding Rack}" FontSize="14" Foreground="{StaticResource TextPrimaryColor}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" TextWrapping="Wrap">
                                                <Run Text="Stock: " FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextSecondaryColor}"/>
                                                <Run Text="{Binding Quantity}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                     
                                     <!-- Print Label Action -->
                                     <Button Command="{Binding DataContext.PrintItemBarcodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             CommandParameter="{Binding}"
                                             Content="Print Barcode Label"
                                             Height="38"
                                             FontSize="14"
                                             FontWeight="SemiBold"
                                             Padding="10,4"
                                             Margin="0,15,0,0"/>
                                 </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Pagination -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Command="{Binding FirstPageCommand}" 
                        Content="&lt;&lt;" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="36" Height="36" 
                        Margin="0,0,8,0" 
                        Padding="0"
                        FontSize="16"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"/>
                
                <Button Command="{Binding PreviousPageCommand}" 
                        Content="&lt;" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="36" Height="36" 
                        Margin="0,0,20,0" 
                        Padding="0"
                        FontSize="16"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"/>
                
                <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryColor}">
                    <Run Text="Page "/>
                    <Run Text="{Binding CurrentPage}"/>
                    <Run Text=" of "/>
                    <Run Text="{Binding TotalPages}"/>
                </TextBlock>

                <Button Command="{Binding NextPageCommand}" 
                        Content="&gt;" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="36" Height="36" 
                        Margin="20,0,8,0" 
                        Padding="0"
                        FontSize="16"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"/>
                
                <Button Command="{Binding LastPageCommand}" 
                        Content="&gt;&gt;" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="36" Height="36" 
                        Padding="0"
                        FontSize="16"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"/>
            </StackPanel>

            <TextBlock Grid.Row="4" 
                       Text="{Binding StatusMessage}" 
                       Foreground="{StaticResource TextSecondaryColor}"
                       FontSize="18"
                       Margin="0,20,0,0"/>
        </Grid>
    </Border>
</UserControl>
