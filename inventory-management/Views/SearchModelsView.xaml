<UserControl x:Class="inventory_management.Views.SearchModelsView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:converters="clr-namespace:inventory_management.Converters"
         mc:Ignorable="d">
<Viewbox Stretch="Uniform" StretchDirection="DownOnly">
    <Border Style="{StaticResource CardBorderStyle}" Margin="20" Width="1920" Height="1080">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource TextPrimaryColor}"
                       Margin="0,0,0,20">
                <Run Text="Select Model for "/>
                <Run Text="{Binding Manufacturer.Name}" FontWeight="Bold"/>
                <Run Text=" "/>
                <Run Text="{Binding Part.Name}" FontWeight="Bold"/>
            </TextBlock>

            <!-- Search Box -->
            <Border Grid.Row="1" 
                    Background="{StaticResource SurfaceColor}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="12,8"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Viewbox Width="20" Height="20" Margin="0,0,10,0">
                        <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                              Fill="{StaticResource TextSecondaryColor}"/>
                    </Viewbox>
                    <TextBox Grid.Column="1" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="20"
                             Padding="0"
                             Margin="0"
                             VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ModelsView}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceColor}"
                                    CornerRadius="12"
                                    Padding="16"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1"
                                    Margin="8" 
                                    Width="280">
                                <Border.Effect>
                                    <DropShadowEffect Color="{Binding Source={StaticResource CardShadowColor}, Path=Color}" 
                                                    BlurRadius="12" 
                                                    ShadowDepth="0" 
                                                    Opacity="0.1"/>
                                </Border.Effect>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Image Width="48" Height="48" Margin="0,0,8,0" 
                                               Source="{Binding PartTypeImagePath, Converter={x:Static converters:RelativeAssetPathToImageSourceConverter.Instance}}"/>
                                        <Image Width="48" Height="48" Margin="0,0,8,0" 
                                               Source="{Binding ManufacturerLogoPath, Converter={x:Static converters:RelativeAssetPathToImageSourceConverter.Instance}}"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="20"
                                                       Foreground="{StaticResource TextPrimaryColor}"/>
                                            <TextBlock Text="{Binding YearRange}" 
                                                       FontSize="16" 
                                                       Foreground="{StaticResource TextSecondaryColor}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Margin="0,0,0,6">
                                        <Run Text="Available Units: " FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryColor}"/>
                                        <Run Text="{Binding Quantity}" Foreground="{StaticResource TextSecondaryColor}"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,0,0,6" TextWrapping="Wrap">
                                        <Run Text="Brand: " FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryColor}"/>
                                        <Run Text="{Binding Brands}" Foreground="{StaticResource TextSecondaryColor}"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,0,0,6" TextWrapping="Wrap">
                                        <Run Text="Rack: " FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryColor}"/>
                                        <Run Text="{Binding Racks}" Foreground="{StaticResource TextSecondaryColor}"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,0,0,6" TextWrapping="Wrap">
                                        <Run Text="Origin: " FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryColor}"/>
                                        <Run Text="{Binding CountriesOfOrigin}" Foreground="{StaticResource TextSecondaryColor}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="3" 
                       Text="{Binding StatusMessage}" 
                       Foreground="{StaticResource TextSecondaryColor}"
                       FontSize="18"
                       Margin="0,20,0,0"/>
        </Grid>
        </Border>
    </Viewbox>
</UserControl>