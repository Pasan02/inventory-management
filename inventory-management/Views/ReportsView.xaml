<UserControl x:Class="inventory_management.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>

        <TabControl Grid.Row="1" Margin="20,10,20,20">
            <TabItem Header="Order Queue (Recent Removed)">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,10,0,10">
                        <Button Content="Send Selected to Ordered Tab" 
                                Command="{Binding PlaceSelectedOrdersCommand}" 
                                Height="36" 
                                Padding="15,0" 
                                FontSize="14"
                                Background="#0078D4" 
                                Foreground="White" 
                                FontWeight="Bold"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid ItemsSource="{Binding RecentRemovedItems}" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="False"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Disabled"
                                  GridLinesVisibility="All"
                                  VerticalGridLinesBrush="#E0E0E0"
                                  HorizontalGridLinesBrush="#E0E0E0"
                                  ColumnHeaderHeight="50"
                                  MinRowHeight="45"
                                  CanUserResizeColumns="True"
                                  Background="White"
                                  RowBackground="White"
                                  AlternatingRowBackground="White"
                                  BorderThickness="0"
                                  HorizontalAlignment="Left"
                                  MaxHeight="600">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="Padding" Value="8"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="50" IsReadOnly="False">
                                    <DataGridTemplateColumn.Header>
                                        <CheckBox IsChecked="{Binding DataContext.SelectAllRecentRemoved, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Type" Binding="{Binding PartType}" Width="SizeToHeader" MinWidth="130" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="SizeToHeader" MinWidth="130" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="SizeToHeader" MinWidth="130" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="SizeToHeader" MinWidth="130" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="SizeToHeader" MinWidth="130" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Qty Removed" Binding="{Binding Quantity}" Width="SizeToHeader" MinWidth="90" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/><Setter Property="TextAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/><Setter Property="HorizontalContentAlignment" Value="Center"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Removed Date" Binding="{Binding CreatedAtLocal}" Width="SizeToHeader" MinWidth="150" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTemplateColumn Header="Action" Width="SizeToHeader" MinWidth="120" IsReadOnly="True">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="Padding" Value="8"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Order" 
                                                    Command="{Binding DataContext.PlaceOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    Height="28" 
                                                    Width="70" 
                                                    Padding="0" 
                                                    FontSize="12"
                                                    Margin="2" 
                                                    Background="#0078D4" 
                                                    Foreground="White" 
                                                    FontWeight="Bold" 
                                                    BorderThickness="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem Header="Ordered Items">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,10,0,10">
                        <Button Content="Mark Selected as Arrived" 
                                Command="{Binding ArriveSelectedOrdersCommand}" 
                                Height="36" 
                                Padding="15,0" 
                                FontSize="14"
                                Background="#2E7D32" 
                                Foreground="White" 
                                FontWeight="Bold"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid ItemsSource="{Binding OrderedItems}" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="False"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Disabled"
                                  GridLinesVisibility="All"
                                  VerticalGridLinesBrush="#E0E0E0"
                                  HorizontalGridLinesBrush="#E0E0E0"
                                  ColumnHeaderHeight="50"
                                  MinRowHeight="45"
                                  CanUserResizeColumns="True"
                                  Background="White"
                                  RowBackground="White"
                                  AlternatingRowBackground="White"
                                  BorderThickness="0"
                                  HorizontalAlignment="Left"
                                  MaxHeight="600">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="Padding" Value="8"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="50" IsReadOnly="False">
                                    <DataGridTemplateColumn.Header>
                                        <CheckBox IsChecked="{Binding DataContext.SelectAllOrdered, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Type" Binding="{Binding PartType}" Width="SizeToHeader" MinWidth="130" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="SizeToHeader" MinWidth="130" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="SizeToHeader" MinWidth="130" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="SizeToHeader" MinWidth="130" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="SizeToHeader" MinWidth="130" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Qty Ordered" Binding="{Binding Quantity}" Width="SizeToHeader" MinWidth="90" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/><Setter Property="TextAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/><Setter Property="HorizontalContentAlignment" Value="Center"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Order Date" Binding="{Binding OrderedAtLocal}" Width="SizeToHeader" MinWidth="150" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8"/><Setter Property="FontSize" Value="14"/></Style></DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="8"/></Style></DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTemplateColumn Header="Action" Width="SizeToHeader" MinWidth="120" IsReadOnly="True">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="Padding" Value="8"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Arrived" 
                                                    Command="{Binding DataContext.ArriveOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    Height="28" 
                                                    Width="70" 
                                                    Padding="0" 
                                                    FontSize="12"
                                                    Margin="2" 
                                                    Background="#2E7D32" 
                                                    Foreground="White" 
                                                    FontWeight="Bold" 
                                                    BorderThickness="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem Header="Stock Snapshot">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <DataGrid ItemsSource="{Binding StockSnapshot}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Disabled"
                              GridLinesVisibility="All"
                              VerticalGridLinesBrush="#E0E0E0"
                              HorizontalGridLinesBrush="#E0E0E0"
                              ColumnHeaderHeight="50"
                              MinRowHeight="45"
                              CanUserResizeColumns="True"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="White"
                              BorderThickness="0"
                              HorizontalAlignment="Left"
                              MaxHeight="600">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="Padding" Value="8"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type" Binding="{Binding PartType}" Width="SizeToHeader" MinWidth="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="FontSize" Value="14"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="8"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="SizeToHeader" MinWidth="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="FontSize" Value="14"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="8"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="SizeToHeader" MinWidth="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="FontSize" Value="14"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="8"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="SizeToHeader" MinWidth="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="FontSize" Value="14"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="8"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="Auto" MinWidth="300">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="TextTrimming" Value="None"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="8"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Cross-Reference" Binding="{Binding CompatibleModelsText}" Width="Auto" MinWidth="180">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="8"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Rack" Binding="{Binding Rack}" Width="SizeToHeader" MinWidth="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="SizeToHeader" MinWidth="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Low" Binding="{Binding LowStockThreshold}" Width="SizeToHeader" MinWidth="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Low Stock">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <DataGrid ItemsSource="{Binding LowStockItems}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Disabled"
                              GridLinesVisibility="All"
                              VerticalGridLinesBrush="#E0E0E0"
                              HorizontalGridLinesBrush="#E0E0E0"
                              ColumnHeaderHeight="50"
                              MinRowHeight="45"
                              CanUserResizeColumns="True"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="White"
                              BorderThickness="0"
                              HorizontalAlignment="Left"
                              MaxHeight="600">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="Padding" Value="8"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type" Binding="{Binding PartType}" Width="SizeToHeader" MinWidth="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="FontSize" Value="14"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="8"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="SizeToHeader" MinWidth="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="FontSize" Value="14"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="8"/>
                                </Style>
