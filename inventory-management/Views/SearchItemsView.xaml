<UserControl x:Class="inventory_management.Views.SearchItemsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:inventory_management.Views"
             xmlns:vmSearch="clr-namespace:inventory_management.ViewModels.Search"
             mc:Ignorable="d">
    <ContentControl Content="{Binding CurrentStep}">
        <ContentControl.Resources>
            <DataTemplate DataType="{x:Type vmSearch:SearchPartsViewModel}">
                <views:SearchPartsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmSearch:SearchManufacturersViewModel}">
                <views:SearchManufacturersView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmSearch:SearchModelsViewModel}">
                <views:SearchModelsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmSearch:SearchAllItemsViewModel}">
                <views:SearchAllItemsView/>
            </DataTemplate>
        </ContentControl.Resources>
    </ContentControl>
</UserControl>